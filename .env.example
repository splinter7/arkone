PINATA_JWT=your_jwt_here
PINATA_GATEWAY=yourname.mypinata.cloud
API_SECRET_KEY=generate_a_long_random_string
LOG_LEVEL=info

# Local SQLite (default if unset): file:./data/local.db
# DATABASE_URL=file:./data/local.db

# Production Turso (set on Vercel)
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=your_token

# Dev only (ignored in production): Node on Windows may fail TLS to Pinata
# PINATA_TLS_INSECURE=true
